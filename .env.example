# Application
APP_NAME=job-aggregator-mcp
APP_ENV=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_aggregator

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Indeed
# INDEED_API_KEY=
# INDEED_PUBLISHER_ID=
# INDEED_COUNTRY=us

# LinkedIn Browser Scraping (no API keys needed — uses browser session)
# LINKEDIN_BROWSER_HEADLESS=true
# LINKEDIN_BROWSER_PROFILE_DIR=~/.linkedin-mcp/profile
# LINKEDIN_BROWSER_NAVIGATION_TIMEOUT=30000
# LINKEDIN_BROWSER_SLOW_MO=100



